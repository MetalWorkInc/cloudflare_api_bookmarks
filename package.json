{
  "name": "cloudflare-api-data",
  "version": "1.0.0",
  "description": "Simple API for data using Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "if exist wrangler.local.toml (wrangler dev --config wrangler.local.toml) else (wrangler dev)",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:ci": "node scripts/generate-wrangler.js",
    "deploy:ci": "node scripts/generate-wrangler.js && wrangler deploy --config wrangler.generated.toml",
    "test": "node test/api-test.js"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "api",
    "data",
    "bookmarks"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251202.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.51.0"
  }
}
